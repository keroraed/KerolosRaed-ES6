{
  "info": {
    "_postman_id": "e22a14db-c779-4605-a1d1-f3479ecf4c74",
    "name": "FlowMart Chat Proxy API",
    "description": "Professional Postman collection for the FlowMart backend chat proxy.\n\nBase URL: {{baseUrl}}\nEndpoint: POST /api/chat\n\nSupported request body modes:\n1) messages mode (UI-compatible)\n- model (string, optional)\n- instructions (string, optional)\n- messages (array)\n  - role: user | assistant\n  - content: string\n  - imageUrl or image_url: optional (user messages)\n\n2) direct input mode (OpenAI Responses API style)\n- model (string, optional)\n- instructions (string, optional)\n- input (array)\n  - role: user | assistant\n  - content supports input_text and input_image parts\n\nAllowed models on proxy:\n- gpt-4o-mini\n- gpt-4.1-mini\n- gpt-5.4 (may return 403 if your project has no access)\n\nResponse body keys:\n- reply (string) on success\n- error (string) on failure\n\nRequired headers:\n- Content-Type: application/json\n- Accept: application/json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Chat - Messages Text (200)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{model}}\",\n  \"instructions\": \"{{instructions}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"{{userMessage}}\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/chat",
        "description": "Sends a standard text-only message list to the proxy."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "let json;",
              "pm.test(\"Response is valid JSON\", function () {",
              "  json = pm.response.json();",
              "  pm.expect(json).to.be.an('object');",
              "});",
              "",
              "pm.test(\"Reply field exists and is non-empty\", function () {",
              "  pm.expect(json).to.have.property('reply');",
              "  pm.expect(json.reply).to.be.a('string');",
              "  pm.expect(json.reply.trim().length).to.be.above(0);",
              "});",
              "",
              "pm.collectionVariables.set('lastReply', json.reply);"
            ]
          }
        }
      ]
    },
    {
      "name": "Chat - Messages With Image URL (200/400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{visionModel}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"what is in this image?\",\n      \"imageUrl\": \"{{imageUrl}}\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/chat",
        "description": "Uses messages mode with imageUrl (same style your frontend sends). Note: external image hosts can return rate-limit/download errors."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const status = pm.response.code;",
              "pm.test(\"Status is 200 or 400\", function () {",
              "  pm.expect([200, 400]).to.include(status);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (status === 200) {",
              "  pm.test(\"Reply exists on success\", function () {",
              "    pm.expect(json.reply).to.be.a('string');",
              "    pm.expect(json.reply.trim().length).to.be.above(0);",
              "  });",
              "} else {",
              "  pm.test(\"Error exists on download failure\", function () {",
              "    pm.expect(json.error).to.be.a('string');",
              "    pm.expect(json.error.trim().length).to.be.above(0);",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Chat - Direct Responses Input (200/400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{visionModel}}\",\n  \"instructions\": \"{{instructions}}\",\n  \"input\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"input_text\",\n          \"text\": \"what is in this image?\"\n        },\n        {\n          \"type\": \"input_image\",\n          \"image_url\": \"{{imageUrl}}\"\n        }\n      ]\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/chat",
        "description": "Uses raw OpenAI Responses API input shape through your proxy."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const status = pm.response.code;",
              "pm.test(\"Status is 200 or 400\", function () {",
              "  pm.expect([200, 400]).to.include(status);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (status === 200) {",
              "  pm.test(\"Reply exists on success\", function () {",
              "    pm.expect(json.reply).to.be.a('string');",
              "    pm.expect(json.reply.trim().length).to.be.above(0);",
              "  });",
              "} else {",
              "  pm.test(\"Error exists on download failure\", function () {",
              "    pm.expect(json.error).to.be.a('string');",
              "    pm.expect(json.error.trim().length).to.be.above(0);",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Chat - Validation Error Empty Payload (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [],\n  \"input\": []\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/chat",
        "description": "Negative test: proxy requires at least one message or one input item."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test(\"Validation error text is returned\", function () {",
              "  pm.expect(json).to.have.property('error');",
              "  pm.expect(json.error).to.be.a('string');",
              "  pm.expect(json.error).to.include('At least one chat message or input item is required');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Chat - Unsupported Model Fallback (200)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"gpt-does-not-exist\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Reply with a short confirmation sentence.\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/chat",
        "description": "Server should fall back to default model when model is unsupported."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test(\"Reply is present after fallback\", function () {",
              "  pm.expect(json.reply).to.be.a('string');",
              "  pm.expect(json.reply.trim().length).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Chat - gpt-5.4 Access Check (200/403)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{advancedModel}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Reply with OK.\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/chat",
        "description": "Checks whether your project can access gpt-5.4. 403 means model access is not enabled for your account/project."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const status = pm.response.code;",
              "pm.test(\"Status is 200 or 403\", function () {",
              "  pm.expect([200, 403]).to.include(status);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (status === 200) {",
              "  pm.test(\"Reply exists when access is enabled\", function () {",
              "    pm.expect(json.reply).to.be.a('string');",
              "    pm.expect(json.reply.trim().length).to.be.above(0);",
              "  });",
              "} else {",
              "  pm.test(\"Error exists when model access is denied\", function () {",
              "    pm.expect(json.error).to.be.a('string');",
              "    pm.expect(json.error.toLowerCase()).to.include('access');",
              "  });",
              "}"
            ]
          }
        }
      ]
    }
  ],
